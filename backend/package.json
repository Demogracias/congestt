{
  "name": "congestt-backend",
  "version": "1.0.0",
  "description": "Backend robusto para gestão de equipes ConGestt",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "pkg": "npm run build && npx @yao-pkg/pkg . --targets node20-win-x64 --output ../dist/ConGestt.exe --compress Brotli"
  },
  "pkg": {
    "scripts": [
      "dist/**/*.js"
    ],
    "assets": [
      "node_modules/better-sqlite3/**/*.node",
      "node_modules/bcryptjs/**/*.js",
      "../frontend/dist/**/*"
    ],
    "public": [
      "../frontend/dist/**/*"
    ]
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.11.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jsonwebtoken": "^9.0.3",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.1.6",
    "vitest": "^4.1.9"
  }
}
